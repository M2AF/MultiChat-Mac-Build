# .env.example — Railway / Server Environment Variables
#
# If you're hosting discord-bridge.js on Railway:
#   1. Copy these into Railway → your service → Variables tab
#   2. Do NOT create a local .env file — use config.js locally instead

DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN
DISCORD_CHANNEL_ID=YOUR_DISCORD_CHANNEL_ID
PORT=8081
